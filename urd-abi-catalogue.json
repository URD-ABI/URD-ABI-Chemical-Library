    "field_reference": {
      "id": "Unique internal reference (required)",
      "name": "Short display name (required)",
      "commonName": "Alternative name or synonym",
      "iupac": "Full IUPAC name (required)",
      "casNumber": "CAS number string or null",
      "family": "Chemical family — see family_values (required)",
      "smiles": "Canonical SMILES string (required)",
      "mw": "Molecular weight as number in g/mol, or string for polymers (required)",
      "logP": "logP as number or null",
      "mp": "Melting point as string, e.g. '89–91°C', or null",
      "solubility": "Solubility description string or null",
      "purity": "Purity string, e.g. '>98%' or null",
      "availability": "'yes', 'limited', or 'no' (required)",
      "applications": "Array of application tags — see application_values",
      "nmr": "true/false — NMR spectra available",
      "uv": "true/false — UV-Vis spectra available",
      "ms": "true/false — Mass spectrum available",
      "svgPath": "SVG string for 2D structure, or '' for auto placeholder",
      "synthesizedBy": "Name or initials of synthesizer",
      "dateAdded": "ISO date string YYYY-MM-DD",
      "notes": "Free text notes (storage, hazards, batch info…)",
      "references": "Array of DOI strings",
      "spectraPaths": "(Optional) Custom paths to spectra files. Overrides the auto-generated path. Example: { \"nmr\": \"spectra/ABI-001/ABI-001_NMR.pdf\", \"uv\": \"spectra/ABI-001/ABI-001_UV.pdf\", \"ms\": \"spectra/ABI-001/ABI-001_MS.pdf\" }. Leave absent to use the auto-generated path: spectra/{id}/{id}_NMR.pdf etc.",
      "formula": "Molecular formula as string, e.g. 'C12H14O5'",
      "bp": "Boiling point as string, e.g. '312°C' or null",
      "storage": "Storage conditions, e.g. 'Room temperature, protect from light' or null",
      "sds": "true/false — Security Data Sheet (SDS) available as PDF",
      "actAntioxidant": "true/false — Antioxidant activity",
      "actAntibacterial": "true/false — Antibacterial activity",
      "actUVFilter": "true/false — UV Filter activity",
      "actPolymer": "true/false — Polymer additive activity"
    }
